{
  "manifest_version": 3,
  "name": "HomeScope",
  "version": "1.0.1",
  "description": "AI-powered property analysis in your browser",
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "HomeScope"
  },
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.realestate.com.au/*",
    "https://*.tryhomescope.com/*",
    "https://trteewgplkqiedonomzg.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html",
    "default_width": 720
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.realestate.com.au/*",
        "https://*.tryhomescope.com/*",
        "https://trteewgplkqiedonomzg.supabase.co/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "privacy_policy_url": "https://tryhomescope.com/privacy",
  "homepage_url": "https://tryhomescope.com",
  "support_url": "support.html"
}
