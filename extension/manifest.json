{
  "manifest_version": 3,
  "name": "HomeScope",
  "version": "1.0.18",
  "description": "AI-powered property analysis in your browser - Supports realestate.com.au and Zillow. For personal use only. Please respect each website's Terms of Service. Do not use for commercial bulk scraping.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png",
    "512": "icon.png"
  },
  "action": {
    "default_title": "HomeScope"
  },
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.zillow.com/*",
    "https://*.zillow.com/*",
    "https://photos.zillowstatic.com/*",
    "https://www.realestate.com.au/*",
    "https://*.realestate.com.au/*",
    "https://*.tryhomescope.com/*",
    "https://trteewgplkqiedonomzg.supabase.co/*",
    "https://wkactamkheskblkdqvza.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html",
    "default_width": 720
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zillow.com/*",
        "https://*.zillow.com/*",
        "https://www.realestate.com.au/*",
        "https://*.realestate.com.au/*",
        "https://*.tryhomescope.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
