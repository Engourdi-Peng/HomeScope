{
  "manifest_version": 3,
  "name": "HomeScope - Property Analyzer",
  "version": "1.0.0",
  "description": "Analyze rental property listings with HomeScope",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.tryhomescope.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["oauth-callback.html", "icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
